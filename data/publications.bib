@unpublished{sagertBuildingHydrodynamicsCode2013,
  title = {Building a {{Hydrodynamics Code}} with {{Kinetic Theory}}},
  author = {Sagert, Irina and Bauer, Wolfgang and Colbry, Dirk and Pickett, Rodney and Strother, Terrance},
  date = {2013-05-17},
  eprint = {1305.4220},
  eprinttype = {arXiv},
  url = {http://arxiv.org/abs/1305.4220},
  urldate = {2013-05-21},
  abstract = {We report on the development of a test-particle based kinetic Monte Carlo code for large systems and its application to simulate matter in the continuum regime. Our code combines advantages of the Direct Simulation Monte Carlo and the Point-of-Closest-Approach methods to solve the collision integral of the Boltzmann equation. With that, we achieve a high spatial accuracy in simulations while maintaining computational feasibility when applying a large number of test-particles. The hybrid setup of our approach allows us to study systems which move in and out of the hydrodynamic regime, with low and high particle densities. To demonstrate our code's ability to reproduce hydrodynamic behavior we perform shock wave simulations and focus here on the Sedov blast wave test. The blast wave problem describes the evolution of a spherical expanding shock front and is an important verification problem for codes which are applied in astrophysical simulation, especially for approaches which aim to study core-collapse supernovae.},
  keywords = {Astrophysics - Instrumentation and Methods for Astrophysics,Physics - Fluid Dynamics},
  file = {/Users/colbrydi/Zotero/storage/PIJ4VCBN/Sagert et al. - 2013 - Building a Hydrodynamics Code with Kinetic Theory.pdf;/Users/colbrydi/Zotero/storage/2S6JQWM8/1305.html}
}

@article{sagertHydrodynamicShockWave2014,
  title = {Hydrodynamic Shock Wave Studies within a Kinetic {{Monte Carlo}} Approach},
  author = {Sagert, Irina and Bauer, Wolfgang and Colbry, Dirk and Howell, Jim and Pickett, Rodney and Staber, Alec and Strother, Terrance},
  date = {2014-06-01},
  journaltitle = {Journal of Computational Physics},
  shortjournal = {Journal of Computational Physics},
  volume = {266},
  pages = {191--213},
  issn = {0021-9991},
  doi = {10.1016/j.jcp.2014.02.019},
  url = {http://www.sciencedirect.com/science/article/pii/S0021999114001399},
  urldate = {2014-03-13},
  abstract = {We introduce a massively parallelized test-particle based kinetic Monte Carlo code that is capable of modeling the phase space evolution of an arbitrarily sized system that is free to move in and out of the continuum limit. Our code combines advantages of the DSMC and the Point of Closest Approach techniques for solving the collision integral. With that, it achieves high spatial accuracy in simulations of large particle systems while maintaining computational feasibility. Using particle mean free paths which are small with respect to the characteristic length scale of the simulated system, we reproduce hydrodynamic behavior. To demonstrate that our code can retrieve continuum solutions, we perform a test-suite of classic hydrodynamic shock problems consisting of the Sod, the Noh, and the Sedov tests. We find that the results of our simulations which apply millions of test-particles match the analytic solutions well. In addition, we take advantage of the ability of kinetic codes to describe matter out of the continuum regime when applying large particle mean free paths. With that, we study and compare the evolution of shock waves in the hydrodynamic limit and in a regime which is not reachable by hydrodynamic codes.},
  keywords = {Fluid dynamics,Kinetic simulation,Monte Carlo,Non-equilibrium,Shock waves},
  file = {/Users/colbrydi/Zotero/storage/NJ749XQP/Sagert et al. - 2014 - Hydrodynamic shock wave studies within a kinetic M.pdf;/Users/colbrydi/Zotero/storage/IQ38P82P/S0021999114001399.html;/Users/colbrydi/Zotero/storage/QSEEYBBS/S0021999114001399.html}
}

@article{sagertKnudsennumberDependenceTwodimensional2015,
  title = {Knudsen-Number Dependence of Two-Dimensional Single-Mode {{Rayleigh-Taylor}} Fluid Instabilities},
  author = {Sagert, Irina and Howell, Jim and Staber, Alec and Strother, Terrance and Colbry, Dirk and Bauer, Wolfgang},
  date = {2015-07},
  journaltitle = {Physical Review. E, Statistical, Nonlinear, and Soft Matter Physics},
  shortjournal = {Phys Rev E Stat Nonlin Soft Matter Phys},
  volume = {92},
  number = {1},
  eprint = {26274271},
  eprinttype = {pubmed},
  pages = {013009},
  issn = {1550-2376},
  doi = {10.1103/PhysRevE.92.013009},
  abstract = {We present a study of single-mode Rayleigh-Taylor instabilities with a modified direct simulation Monte Carlo (MDSMC) code in two dimensions. The MDSMC code is aimed to capture the dynamics of matter for a large range of Knudsen numbers within one approach. Our method combines the traditional Monte Carlo technique to efficiently propagate particles and the point-of-closest-approach method for high spatial resolution. Simulations are performed using different particle mean free paths and we compare the results to linear theory predictions for the growth rate including diffusion and viscosity. We find good agreement between theoretical predictions and simulations and, at late times, observe the development of secondary instabilities, similar to hydrodynamic simulations and experiments. Large mean free paths favor particle diffusion, reduce the occurrence of secondary instabilities, and approach the noninteracting gas limit.},
  langid = {english},
  file = {/Users/colbrydi/Zotero/storage/6N93WUWA/Sagert et al. - 2015 - Knudsen-number dependence of two-dimensional singl.pdf;/Users/colbrydi/Zotero/storage/I76WIQFW/Sagert et al. - 2015 - Knudsen-number dependence of two-dimensional singl.pdf;/Users/colbrydi/Zotero/storage/A8RVMCUB/PhysRevE.92.html}
}

